# Best validated overnight variant for RTX 5090 platform
CUDA3D_FINAL_VARIANT=zmem_reference
CUDA3D_FINAL_REASON="No post-zmem candidate reached >=2% repeat speedup"
CUDA3D_NVFLAGS="-O3 -arch=sm_120 --use_fast_math -DCUDA3D_PML_RECOMPUTE_Z -DCUDA3D_PML_TILE_LIST -DCUDA3D_PML_ZMEM_IN_P -DPmlTileBlockSize1=32 -DPmlTileBlockSize2=4 -DPmlTileBlockSize3=2"
CUDA3D_MAKEFILE=src/makefile.rtx5090
CUDA3D_BINARY=bin/cuda_3D_FM
